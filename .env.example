# DeepSeek is OpenAI-compatible. You can use either variable name.
DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.deepseek.com

# Optional. DeepSeek's cheap model for daily and weekly summaries.
AI_RADAR_DAILY_MODEL=deepseek-v4-flash
AI_RADAR_WEEKLY_MODEL=deepseek-v4-flash
